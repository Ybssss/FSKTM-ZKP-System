# File upload storage
# Stores uploaded session materials in MongoDB GridFS.
FILE_STORAGE_PROVIDER=gridfs
GRIDFS_BUCKET_NAME=session_materials
MAX_FILE_SIZE=10485760

# Used to generate absolute file-view URLs after upload.
# Local:
PUBLIC_BACKEND_URL=http://localhost:5000
# Render:
# PUBLIC_BACKEND_URL=https://fsktm-backend.onrender.com
