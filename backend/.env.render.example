MONGO_URI=mongodb+srv://...
JWT_SECRET=replace-with-a-long-random-secret

# Recommended on Render: HTTPS email API, because SMTP ports can time out.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...
EMAIL_FROM=FSKTM ZKP System <noreply@your-verified-domain.com>

# Local fallback: Gmail SMTP. Use a Gmail App Password, not your normal Gmail password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your-16-character-app-password

# Optional, but useful when links/files need the deployed backend origin.
PUBLIC_BACKEND_URL=https://your-render-service.onrender.com

# Vercel frontend origin allowed by CORS.
FRONTEND_URL=https://your-vercel-project.vercel.app
